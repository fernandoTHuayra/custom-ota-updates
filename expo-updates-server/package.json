{
  "name": "custom-expo-updates-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env PRIVATE_KEY_PATH=code-signing-keys/private-key.pem next dev --turbopack",
    "build": "next build",
    "start": "cross-env PRIVATE_KEY_PATH=code-signing-keys/private-key.pem node server.js",
    "lint": "eslint common pages",
    "test": "jest",
    "init-db": "node scripts/init-db.js",
    "publish-remote": "node ./scripts/publish-remote.js",
    "publish-remote:android": "cross-env EXPO_PUBLISH_PLATFORMS=android node ./scripts/publish-remote.js",
    "publish-remote:ios": "cross-env EXPO_PUBLISH_PLATFORMS=ios node ./scripts/publish-remote.js"
  },
  "dependencies": {
    "form-data": "^4.0.4",
    "next": "15.5.3",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "structured-headers": "^0.4.1"
  },
  "devDependencies": {
    "@expo/config": "^12.0.9",
    "@expo/multipart-body-parser": "^2.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.1",
    "@types/react": "19.1.13",
    "cross-env": "^10.1.0",
    "eslint": "^9.35.0",
    "eslint-config-universe": "^15.0.3",
    "jest": "^30.1.3",
    "node-mocks-http": "^1.17.2",
    "nullthrows": "^1.1.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  },
  "resolutions": {
    "@types/react": "19.1.13"
  }
}
