# Production environment — VPS (otaupdates.huayra.com.ar)
HOSTNAME=https://otaupdates.huayra.com.ar:3000
ASSETS_BASE_URL=https://otaupdates.huayra.com.ar:3000/updates/assets
PRIVATE_KEY_PATH=code-signing-keys/private-key.pem

# SSL certificates (Virtualmin / Let's Encrypt)
SSL_CERT_PATH=/home/otaupdates/ssl/ssl.cert
SSL_KEY_PATH=/home/otaupdates/ssl/ssl.key
SSL_CA_PATH=/home/otaupdates/ssl/ssl.ca
