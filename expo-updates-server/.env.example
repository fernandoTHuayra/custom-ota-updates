# ─── Server (VPS) ──────────────────────────────────────────────────────────────
# These are used when running the server in production (node server.js / next dev)

NODE_ENV=production
PORT=3000

# Public URL of this server (used to build asset URLs in manifests)
HOSTNAME=https://your-domain.com:3000

# Public certificate used to verify publish signatures
# Place certificate.pem in the root of expo-updates-server/

# API key to protect the POST /api/publish endpoint
# Generate one with: openssl rand -hex 32
PUBLISH_API_KEY=

# SSL certificates (optional — if not set, server falls back to HTTP)
SSL_CERT_PATH=
SSL_KEY_PATH=
SSL_CA_PATH=

